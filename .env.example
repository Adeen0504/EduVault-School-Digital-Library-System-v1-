# ╔══════════════════════════════════════════════════════════════════╗
# ║          EduVault — Environment Variables Template               ║
# ║                                                                  ║
# ║  Copy this file to .env and fill in your real values            ║
# ║  cp .env.example .env                                           ║
# ║                                                                  ║
# ║  NEVER commit .env to GitHub — it contains real passwords       ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── GMAIL STORAGE ──────────────────────────────────────────────────
# The Gmail account where all uploaded files will be stored
GMAIL_ADDRESS=your_email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get it:
#   1. myaccount.google.com → Security
#   2. Turn ON 2-Step Verification
#   3. Search "App Passwords"
#   4. App: Mail | Device: Other → name it "EduVault"
#   5. Copy the 16-character password here
GMAIL_APP_PASS=your_app_password_here

# ── FLASK SECURITY ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EDUVAULT_SECRET=change-this-to-a-long-random-string

# ── SERVER ─────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false
